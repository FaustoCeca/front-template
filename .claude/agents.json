{
  "agents": {
    "react-slave": {
      "id": "react-slave",
      "name": "React Slave",
      "description": "Fast, lightweight agent for small JavaScript/React tasks",
      "model": "claude-3-5-haiku",
      "enabled": true,
      "shortcuts": {
        "fix": "react-slave",
        "quick": "react-slave",
        "small": "react-slave",
        "css": "react-slave",
        "style": "react-slave"
      }
    },
    "architect": {
      "id": "architect",
      "name": "Architect",
      "description": "Expert agent for features, routing, and implementation",
      "model": "claude-3-5-sonnet",
      "enabled": true,
      "shortcuts": {
        "feature": "architect",
        "implement": "architect",
        "route": "architect",
        "refactor": "architect",
        "integration": "architect"
      }
    },
    "full-stack-master": {
      "id": "full-stack-master",
      "name": "Full Stack Master",
      "description": "Advanced agent for system design and architecture",
      "model": "claude-3-5-sonnet",
      "enabled": true,
      "shortcuts": {
        "architecture": "full-stack-master",
        "design": "full-stack-master",
        "system": "full-stack-master",
        "performance": "full-stack-master",
        "optimize": "full-stack-master"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(bun --version)",
      "Bash(bun add react react-dom @tanstack/react-router @tanstack/react-query)",
      "Bash(bun add -d typescript @types/react @types/react-dom vite @vitejs/plugin-react tailwindcss @tailwindcss/vite @biomejs/biome)",
      "Bash(bun run build)",
      "Bash(bun add -d @types/node)",
      "Bash(bun run lint)"
    ]
  },
  "contextSettings": {
    "includeProjectStructure": true,
    "includeSkills": true,
    "maxContextTokens": {
      "react-slave": 20000,
      "architect": 200000,
      "full-stack-master": 200000
    }
  },
  "agentHandoff": {
    "autoEscalate": true,
    "escalationThreshold": "complexity",
    "deescalationAllowed": true
  }
}
